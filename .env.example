# Optional: Discord channel webhook — omit for release-only runs (Server Settings → Integrations → Webhooks)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Curation: two-step OpenAI agents (shortlist → writer). Without this, digest is uncurated links only.
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Optional: write digest to disk (CI sets this to newsletter/digest.md for GitHub Releases)
# NEWSLETTER_ARTIFACT_PATH=newsletter/digest.md

# GitHub Actions: Repo → Settings → Secrets and variables
#   Secrets (optional): DISCORD_WEBHOOK_URL, OPENAI_API_KEY
#   Variables (optional): OPENAI_MODEL
# Each run creates a Release (body + digest.md). Discord only if DISCORD_WEBHOOK_URL is set.

# RSS/Atom feeds: comma or newline separated.
# Unset = defaults to HuggingFace Blog, Google AI Blog, MIT Tech Review.
# Set RSS_FEED_URLS= (empty) to disable RSS sourcing.
# RSS_FEED_URLS=https://huggingface.co/blog/feed.xml,https://blog.google/technology/ai/rss/

# Optional
# MAX_MESSAGE_CHARS=1800
# DRY_RUN=1
